# ── Finalytics root environment ──
# Copy to ".env" and fill in real values. The .env file is gitignored.

# Backend JWT signing secret (use a long random string in production)
SECRET_KEY=change-me-to-a-long-random-string

# OpenAI — powers the Risk Analyst & Sales Strategist agents (US13, US14)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# SERP module
SERP_API_KEY=dev-secret-key
SERPAPI_API_KEY=your-serpapi-key-here

# ONRC credentials for the BERC module
ONRC_USERNAME=your-onrc-username
ONRC_PASSWORD=your-onrc-password

# ── Deployment (production) ──
# Publish the frontend on port 80 in production (default 8080 for local dev).
FRONTEND_PORT=8080
# Bind internal service ports to localhost only in production (set to "127.0.0.1:").
# Leave empty for local development so you can hit services directly.
BIND=
