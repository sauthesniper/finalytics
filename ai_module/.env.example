# OpenAI configuration for the AI agents (US9, US13, US14)
OPENAI_API_KEY=change-me
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=40

# Internal service URLs (defaults match docker-compose service names)
ANAF_URL=http://anaf-api:8002
INTEL_URL=http://intel-api:8000
SERP_URL=http://serp-api:3000
SERP_API_KEY=dev-secret-key

# CORS
ALLOWED_ORIGINS=*
